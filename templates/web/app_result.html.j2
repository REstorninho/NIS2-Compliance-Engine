<!DOCTYPE html>
<html lang="pt">
<head>
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1"/>
<title>{{ brand }} · Resultados</title>
<style>
:root { --accent:#1f4e79; --muted:#666; --border:#d6dbe0; --warn:#b5840a; }
*{box-sizing:border-box}
body{font-family:-apple-system,"Segoe UI",Roboto,Helvetica,Arial,sans-serif;color:#1a1a1a;margin:0;background:#f4f6f8}
header{background:var(--accent);color:#fff;padding:16px 28px}
header .brand{font-size:13px;letter-spacing:2px;text-transform:uppercase;opacity:.85}
header h1{margin:4px 0 0;font-size:22px}
main{max-width:920px;margin:0 auto;padding:24px}
.card{background:#fff;border:1px solid var(--border);border-radius:10px;padding:20px 22px;margin-bottom:18px}
.card h2{margin:0 0 14px;font-size:17px;color:var(--accent)}
.kpis{display:flex;gap:14px;flex-wrap:wrap}
.kpi{flex:1;min-width:140px;background:#eef2f6;border-radius:8px;padding:12px 14px}
.kpi .l{font-size:12px;color:var(--muted)}
.kpi .v{font-size:20px;font-weight:700;color:var(--accent)}
.files{list-style:none;padding:0;margin:0}
.files li{display:flex;justify-content:space-between;align-items:center;padding:8px 0;border-bottom:1px solid var(--border)}
.btn{display:inline-block;background:var(--accent);color:#fff;border:0;border-radius:6px;padding:8px 14px;font-size:13px;font-weight:600;cursor:pointer;text-decoration:none}
.btn.secondary{background:#fff;color:var(--accent);border:1px solid var(--accent)}
.aviso{background:#fff7e6;border:1px solid #f0d48a;border-radius:8px;padding:8px 12px;font-size:13px;margin-top:8px}
.err{background:#fbe9e9;border:1px solid #e0a0a0;border-radius:8px;padding:14px;color:#a11}
.actions{display:flex;gap:10px;flex-wrap:wrap;margin-top:6px}
a.back{color:#fff;text-decoration:underline}
</style>
</head>
<body>
<header>
  <div class="brand">{{ brand }}</div>
  <h1>Resultados · <a class="back" href="/">novo</a></h1>
</header>
<main>

{% if error %}
  <div class="card"><div class="err"><strong>Não foi possível gerar:</strong> {{ error|e }}</div></div>
{% else %}

  <div class="card">
    <h2>{{ result.entity_name|e }}</h2>
    <div class="kpis">
      <div class="kpi"><div class="l">Tipo de entidade</div><div class="v">{{ result.entity_type }}</div></div>
      <div class="kpi"><div class="l">Nível de referência</div><div class="v">{{ result.nivel_referencia }}</div></div>
      <div class="kpi"><div class="l">Nível efetivo</div><div class="v">{{ result.nivel_efetivo }}</div></div>
      {% if result.score_pct is not none %}
      <div class="kpi"><div class="l">Conformidade</div><div class="v">{{ result.score_pct }}%</div></div>
      <div class="kpi"><div class="l">Maturidade média</div><div class="v">{{ result.maturity_pct }}%</div></div>
      <div class="kpi"><div class="l">Gaps abertos</div><div class="v">{{ result.open_gaps }}</div></div>
      {% endif %}
    </div>
    {% for aviso in result.avisos %}
      <div class="aviso">⚠️ {{ aviso|e }}</div>
    {% endfor %}
  </div>

  <div class="card">
    <h2>Exportar</h2>
    <div class="actions">
      <a class="btn" href="/download/{{ sid }}/_all.zip">⬇ Todos (.zip Markdown)</a>
      <a class="btn" href="/download/{{ sid }}/dossier.pdf">⬇ Dossier (PDF)</a>
      <a class="btn secondary" href="/download/{{ sid }}/dossier.html">⬇ Dossier (HTML imprimível)</a>
    </div>
    <p class="aviso" style="margin-top:12px">Se o servidor não tiver motor de PDF, descarrega o dossier HTML e usa Imprimir → Guardar como PDF no browser.</p>
  </div>

  <div class="card">
    <h2>Deliverables gerados ({{ result.files|length }})</h2>
    <ul class="files">
      {% for f in result.files %}
      <li><span>{{ f|e }}</span><a class="btn secondary" href="/download/{{ sid }}/{{ f|urlencode }}">⬇ Markdown</a></li>
      {% endfor %}
    </ul>
  </div>

{% endif %}

</main>
</body>
</html>
