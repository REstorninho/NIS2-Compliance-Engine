<!DOCTYPE html>
<html lang="pt">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ brand }} — Conformidade NIS2</title>
<style>
  :root { --azul: #2b6cb0; --verde: #2f855a; --ambar: #b7791f; --vermelho: #c53030; --cinza: #718096; --fundo: #f7fafc; }
  * { box-sizing: border-box; }
  body { font-family: -apple-system, "Segoe UI", Roboto, sans-serif; margin: 0; background: var(--fundo); color: #1a202c; }
  header { background: var(--azul); color: #fff; padding: 18px 24px; }
  header h1 { margin: 0; font-size: 20px; }
  header p { margin: 4px 0 0; opacity: .85; font-size: 13px; }
  main { max-width: 1040px; margin: 24px auto; padding: 0 16px; display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
  @media (max-width: 760px) { main { grid-template-columns: 1fr; } }
  .card { background: #fff; border: 1px solid #e2e8f0; border-radius: 10px; padding: 20px; }
  .full { grid-column: 1 / -1; }
  .card h2 { margin: 0 0 14px; font-size: 16px; }
  .card h3 { margin: 18px 0 8px; font-size: 14px; color: #2d3748; }
  label { display: block; font-size: 13px; font-weight: 600; margin: 12px 0 4px; }
  input[type=text], input[type=number], select { width: 100%; padding: 9px 10px; border: 1px solid #cbd5e0; border-radius: 6px; font-size: 14px; }
  .check { display: flex; align-items: center; gap: 8px; margin-top: 12px; font-weight: 400; font-size: 13px; }
  .check input { width: auto; }
  .hint { font-size: 12px; color: var(--cinza); margin-top: 3px; }
  .result { text-align: center; padding: 20px; border-radius: 10px; margin-bottom: 14px; }
  .result .tipo { font-size: 22px; font-weight: 700; margin: 6px 0; }
  .result .nivel { font-size: 14px; }
  .r-essencial { background: #ebf8ff; border: 1px solid var(--azul); }
  .r-importante { background: #f0fff4; border: 1px solid var(--verde); }
  .r-publica { background: #faf5ff; border: 1px solid #805ad5; }
  .r-fora { background: #fffaf0; border: 1px solid var(--ambar); }
  .motivo { font-size: 13px; color: #4a5568; }
  button { cursor: pointer; border: none; border-radius: 6px; padding: 10px 14px; font-size: 14px; font-weight: 600; }
  .btn-primary { background: var(--azul); color: #fff; }
  .btn-ghost { background: #edf2f7; color: #2d3748; }
  .actions { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 14px; }
  table { width: 100%; border-collapse: collapse; font-size: 13px; }
  th, td { text-align: left; padding: 7px 8px; border-bottom: 1px solid #edf2f7; }
  th { color: var(--cinza); font-weight: 600; }
  .badge { display: inline-block; padding: 2px 8px; border-radius: 999px; font-size: 11px; font-weight: 700; }
  .b-essencial { background: #ebf8ff; color: var(--azul); }
  .b-importante { background: #f0fff4; color: var(--verde); }
  .b-publica { background: #faf5ff; color: #805ad5; }
  .b-fora { background: #fffaf0; color: var(--ambar); }
  .b-alta { background: #fff5f5; color: var(--vermelho); }
  .b-media { background: #fffaf0; color: var(--ambar); }
  .b-baixa { background: #f0fff4; color: var(--verde); }
  .vazio { color: var(--cinza); font-style: italic; font-size: 13px; }
  .hidden { display: none; }
  .kpis { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 8px; }
  .kpi { flex: 1; min-width: 120px; text-align: center; background: var(--fundo); border: 1px solid #e2e8f0; border-radius: 8px; padding: 12px; }
  .kpi .v { font-size: 24px; font-weight: 700; color: var(--azul); }
  .kpi .l { font-size: 12px; color: var(--cinza); }
  .q-fn { font-weight: 700; font-size: 13px; margin: 14px 0 4px; color: var(--azul); }
  .q-row { display: grid; grid-template-columns: 1fr 150px; gap: 10px; align-items: center; padding: 6px 0; border-bottom: 1px solid #f1f5f9; }
  .q-row .t { font-size: 13px; }
  .q-row .t small { color: var(--cinza); }
  .q-row select { padding: 6px; font-size: 13px; }
  #risk-table input { width: 100%; padding: 5px 6px; font-size: 13px; border: 1px solid #cbd5e0; border-radius: 5px; }
  #risk-table input.num { width: 64px; text-align: center; }
  #risk-table td.valor { font-weight: 700; color: var(--azul); text-align: right; }
  .btn-x { background: #fff5f5; color: var(--vermelho); border: none; border-radius: 5px; padding: 4px 8px; cursor: pointer; font-weight: 700; }
  footer { max-width: 1040px; margin: 0 auto 40px; padding: 0 16px; font-size: 12px; color: var(--cinza); }
  .aviso { background: #fffaf0; border: 1px solid #f6e05e; border-radius: 8px; padding: 12px; font-size: 12px; color: #744210; margin-top: 16px; }
</style>
</head>
<body>
<header>
  <h1>{{ brand }} — Conformidade NIS2</h1>
  <p>Classificação de âmbito e autoavaliação de maturidade (DL 125/2025 + Regulamento n.º 756/2026). Tudo corre no teu browser — nenhum dado é enviado para fora.</p>
</header>

<script id="nis2-config" type="application/json">{{ config_json }}</script>

<main>
  <section class="card">
    <h2>1 · Perfil da entidade</h2>
    <label for="name">Nome da entidade</label>
    <input type="text" id="name" placeholder="Ex.: Câmara Municipal de Exemplo">

    <label for="sector">Setor</label>
    <select id="sector"></select>
    <div class="hint" id="sector-hint"></div>

    <label for="employees">Número de trabalhadores</label>
    <input type="number" id="employees" min="0" value="0">

    <label for="turnover">Volume de negócios anual (€)</label>
    <input type="number" id="turnover" min="0" value="0">

    <label class="check"><input type="checkbox" id="is_public_body"> É organismo da Administração Pública</label>
    <label class="check"><input type="checkbox" id="is_trust"> É prestador de DNS / registo de TLD / serviços de confiança qualificados</label>

    <div class="actions">
      <button class="btn-primary" id="btn-save">Guardar classificação no histórico</button>
      <button class="btn-ghost" id="btn-yaml">Descarregar perfil (YAML)</button>
    </div>
  </section>

  <section class="card">
    <h2>Resultado da classificação</h2>
    <div id="result"></div>
    <div class="motivo" id="motivo"></div>
  </section>

  <section class="card full hidden" id="risk-card">
    <h2>2 · Matriz de Risco (Anexo II)</h2>
    <p class="hint" id="risk-intro"></p>
    <table id="risk-table">
      <thead>
        <tr><th>Cenário</th><th>Ator / ameaça</th><th>Prob. (1-5)</th><th>Impacto (1-5)</th><th>Valor</th><th></th></tr>
      </thead>
      <tbody id="risk-rows"></tbody>
    </table>
    <div class="actions">
      <button class="btn-ghost" id="btn-add-scenario">+ Adicionar cenário</button>
    </div>
    <div class="kpis" id="risk-kpis"></div>
    <p class="hint">Fórmula: <code>valor = Probabilidade × Impacto × (Dimensão/3) × Tipo de setor</code>.
      Limiares: Básico 0–99 · Substancial 100–199 · Elevado 200–1200.
      Quando há cenários, o nível efetivo (agregação art. 30.º) é usado na autoavaliação abaixo.</p>
  </section>

  <section class="card full" id="assess-card">
    <h2>3 · Autoavaliação de maturidade</h2>
    <p class="hint" id="assess-intro"></p>
    <div id="questionnaire"></div>
  </section>

  <section class="card full hidden" id="results-card">
    <h2>4 · Resultado da autoavaliação</h2>
    <div class="kpis" id="kpis"></div>
    <h3>Maturidade média por função QNRCS</h3>
    <div id="by-function"></div>
    <h3>Roadmap de remediação (gaps por fase)</h3>
    <div id="roadmap"></div>
    <h3>Radar de maturidade</h3>
    <div id="radar" style="text-align:center;"></div>
    <div class="actions">
      <button class="btn-ghost" id="btn-answers">Descarregar respostas (YAML p/ nis2 assess)</button>
      <button class="btn-primary" id="btn-report">Descarregar relatório (HTML)</button>
    </div>
  </section>

  <section class="card full">
    <h2>Histórico de classificações</h2>
    <div id="history"></div>
    <div class="actions">
      <button class="btn-ghost" id="btn-export">Exportar histórico (CSV)</button>
      <button class="btn-ghost" id="btn-clear">Limpar histórico</button>
    </div>
  </section>
</main>

<footer>
  <div class="aviso">
    <strong>Aviso:</strong> a classificação é <strong>provisória e de apoio à decisão</strong> — a qualificação definitiva é da autoridade competente (CNCS ou autoridade setorial). A autoavaliação de maturidade depende de uma resposta honesta por controlo e não substitui evidência técnica/documental verificável. As listas de setores e medidas ainda estão por validar artigo-a-artigo contra o texto oficial (Diário da República).
  </div>
</footer>

<script>
(function () {
  "use strict";
  var CFG = JSON.parse(document.getElementById("nis2-config").textContent);
  var STORAGE_KEY = "nis2-classificacoes";
  var el = function (id) { return document.getElementById(id); };
  var answersState = {}; // control_id -> maturity (0-5)

  // Preenche o dropdown de setores a partir da config injetada pelo motor.
  CFG.sectors.forEach(function (s) {
    var opt = document.createElement("option");
    opt.value = s.value;
    opt.textContent = s.label + " (" + s.grupo + ")";
    el("sector").appendChild(opt);
  });

  // --- Classificação: replica classify_entity() do motor (classification.py) ---
  function classify(entity) {
    if (entity.is_public_body) return { tipo: "entidade_publica_relevante", motivo: "Organismo da Administração Pública." };
    if (entity.is_trust) return { tipo: "essencial", motivo: "Prestador de DNS/TLD/serviços de confiança — essencial independentemente da dimensão." };
    var meetsSize = entity.employees >= CFG.size_employees || entity.turnover > CFG.size_turnover;
    if (!meetsSize) return { tipo: "fora_de_ambito", motivo: "Não atinge a regra de dimensão (≥" + CFG.size_employees + " trab. OU >" + fmtEur(CFG.size_turnover) + ")." };
    if (CFG.essenciais.indexOf(entity.sector) >= 0) return { tipo: "essencial", motivo: "Setor essencial (Anexo I) e atinge a regra de dimensão." };
    if (CFG.importantes.indexOf(entity.sector) >= 0) return { tipo: "importante", motivo: "Setor importante (Anexo II) e atinge a regra de dimensão." };
    return { tipo: "fora_de_ambito", motivo: "Setor não consta dos Anexos I/II — só entra em âmbito por via da cadeia de fornecimento." };
  }

  var LEVELS = CFG.level_mapping;
  var META = {
    essencial: { rotulo: "Essencial", cls: "essencial" },
    importante: { rotulo: "Importante", cls: "importante" },
    entidade_publica_relevante: { rotulo: "Entidade Pública Relevante", cls: "publica" },
    fora_de_ambito: { rotulo: "Fora de âmbito", cls: "fora" }
  };

  function fmtEur(v) { return new Intl.NumberFormat("pt-PT", { style: "currency", currency: "EUR", maximumFractionDigits: 0 }).format(v); }
  function round1(x) { return Math.round(x * 10) / 10; }
  function round2(x) { return Math.round(x * 100) / 100; }
  function fmtG(v) { return parseFloat(Number(v).toFixed(2)).toString(); } // imita Python {:g}

  // --- Matriz de Risco (Anexo II): replica risk_matrix.py ---
  var RISK = CFG.risk;
  var riskScenarios = [{ name: "Ransomware", actor: "Cibercrime organizado", prob: 4, impacto: 5 }];

  function classifyDimensao(entity) {
    var b = RISK.dimensao_bands;
    if (entity.employees >= b.grande_emp || entity.turnover > b.grande_turn) return "grande";
    if (entity.employees >= b.media_emp || entity.turnover > b.media_turn) return "media";
    return "pequena";
  }
  function classifyTipoSetor(entity) {
    if (entity.is_public_body || CFG.essenciais.indexOf(entity.sector) >= 0) return "importancia_critica";
    return "outros_criticos";
  }
  function classifyRiskLevel(total) {
    if (total >= RISK.limiar_elevado) return "elevado";
    if (total >= RISK.limiar_substancial) return "substancial";
    return "basico";
  }
  function mostDemanding(a, b) {
    var ord = RISK.level_order;
    var arr = [a, b].filter(function (x) { return x; });
    if (!arr.length) return "basico";
    return arr.reduce(function (m, x) { return ord[x] > ord[m] ? x : m; });
  }
  function buildRiskMatrix(entity, scenarios, nivelReferencia) {
    var dim = classifyDimensao(entity), tipo = classifyTipoSetor(entity);
    var dimF = RISK.dimensao_fator[dim], tipoF = RISK.tipo_setor_fator[tipo];
    var results = scenarios.map(function (s) {
      return { s: s, valor: round2(s.prob * s.impacto * dimF * tipoF) };
    });
    var total = round2(results.reduce(function (acc, r) { return acc + r.valor; }, 0));
    var nivelMatriz = classifyRiskLevel(total);
    return {
      dimensao: dim, dimensaoFator: dimF, tipoSetor: tipo, tipoSetorFator: tipoF,
      results: results, total: total, nivelMatriz: nivelMatriz,
      nivelReferencia: nivelReferencia || null,
      nivelEfetivo: mostDemanding(nivelMatriz, nivelReferencia)
    };
  }
  function effectiveLevelFor(entity) {
    var nivel = LEVELS[classify(entity).tipo];
    if (!nivel) return nivel;
    if (riskScenarios.length > 0) return buildRiskMatrix(entity, riskScenarios, nivel).nivelEfetivo;
    return nivel;
  }
  function updateRiskKpis(m) {
    el("risk-kpis").innerHTML =
      '<div class="kpi"><div class="v">' + m.total + '</div><div class="l">Valor de risco</div></div>' +
      '<div class="kpi"><div class="v">' + m.nivelMatriz + '</div><div class="l">Nível pela matriz</div></div>' +
      '<div class="kpi"><div class="v">' + (m.nivelReferencia || "—") + '</div><div class="l">Nível por tipo</div></div>' +
      '<div class="kpi"><div class="v">' + m.nivelEfetivo + '</div><div class="l">Nível efetivo (art. 30.º)</div></div>';
  }
  function recomputeRiskValues(entity, nivelRef) {
    var m = buildRiskMatrix(entity, riskScenarios, nivelRef);
    var trs = el("risk-rows").querySelectorAll("tr");
    m.results.forEach(function (r, i) {
      if (trs[i]) { var vc = trs[i].querySelector(".valor"); if (vc) vc.textContent = r.valor; }
    });
    updateRiskKpis(m);
    renderQuestionnaire(m.nivelEfetivo);
  }
  function renderRiskMatrix(c) {
    var card = el("risk-card");
    if (!c.nivel) { card.classList.add("hidden"); return c.nivel; }
    card.classList.remove("hidden");
    var m = buildRiskMatrix(c.entity, riskScenarios, c.nivel);
    el("risk-intro").innerHTML = "Dimensão: <strong>" + m.dimensao + "</strong> (fator " + fmtG(m.dimensaoFator) +
      ") · Tipo de setor: <strong>" + m.tipoSetor.replace(/_/g, " ") + "</strong> (fator " + m.tipoSetorFator + ").";
    var rows = "";
    riskScenarios.forEach(function (s, i) {
      var valor = m.results[i] ? m.results[i].valor : 0;
      rows += '<tr>' +
        '<td><input data-i="' + i + '" data-k="name" value="' + escapeHtml(s.name) + '"></td>' +
        '<td><input data-i="' + i + '" data-k="actor" value="' + escapeHtml(s.actor || "") + '"></td>' +
        '<td><input type="number" min="1" max="5" class="num" data-i="' + i + '" data-k="prob" value="' + s.prob + '"></td>' +
        '<td><input type="number" min="1" max="5" class="num" data-i="' + i + '" data-k="impacto" value="' + s.impacto + '"></td>' +
        '<td class="valor">' + valor + '</td>' +
        '<td><button class="btn-x" data-del="' + i + '">✕</button></td></tr>';
    });
    el("risk-rows").innerHTML = rows;
    el("risk-rows").querySelectorAll("input").forEach(function (inp) {
      inp.addEventListener("input", function () {
        var i = parseInt(inp.getAttribute("data-i"), 10), k = inp.getAttribute("data-k");
        if (k === "prob" || k === "impacto") {
          riskScenarios[i][k] = Math.max(1, Math.min(5, parseInt(inp.value, 10) || 1));
          recomputeRiskValues(c.entity, c.nivel); // não reconstrói a tabela → mantém o foco
        } else {
          riskScenarios[i][k] = inp.value;
        }
      });
    });
    el("risk-rows").querySelectorAll("button[data-del]").forEach(function (b) {
      b.addEventListener("click", function () {
        riskScenarios.splice(parseInt(b.getAttribute("data-del"), 10), 1);
        render();
      });
    });
    updateRiskKpis(m);
    return m.nivelEfetivo;
  }

  // --- Radar SVG: replica render_maturity_radar_svg() do motor (charts.py) ---
  function radarSvg(byFn, size) {
    size = size || 420;
    var order = CFG.radar_order || [];
    var functions = order.filter(function (f) { return f in byFn; });
    Object.keys(byFn).forEach(function (f) { if (functions.indexOf(f) < 0) functions.push(f); });
    var n = functions.length;
    if (n < 3) return '<svg xmlns="http://www.w3.org/2000/svg" width="' + size + '" height="40"><text x="8" y="24">Dados insuficientes para o radar.</text></svg>';
    var cx = size / 2, cy = size / 2, margin = 70, maxR = size / 2 - margin, MAX = 5;
    var angles = functions.map(function (_, i) { return (-Math.PI / 2) + (2 * Math.PI * i / n); });
    function pt(r, a) { return [cx + r * Math.cos(a), cy + r * Math.sin(a)]; }
    var p = [];
    p.push('<svg xmlns="http://www.w3.org/2000/svg" width="' + size + '" height="' + size + '" viewBox="0 0 ' + size + ' ' + size + '" font-family="sans-serif">');
    p.push('<rect width="' + size + '" height="' + size + '" fill="#ffffff"/>');
    p.push('<text x="' + cx + '" y="24" text-anchor="middle" font-size="15" font-weight="bold" fill="#1a1a1a">Maturidade por função (QNRCS)</text>');
    for (var ring = 1; ring <= MAX; ring++) {
      var r = maxR * ring / MAX;
      var rp = angles.map(function (a) { var q = pt(r, a); return q[0].toFixed(1) + "," + q[1].toFixed(1); }).join(" ");
      p.push('<polygon points="' + rp + '" fill="none" stroke="#dddddd" stroke-width="1"/>');
    }
    functions.forEach(function (func, i) {
      var a = angles[i], ax = pt(maxR, a);
      p.push('<line x1="' + cx.toFixed(1) + '" y1="' + cy.toFixed(1) + '" x2="' + ax[0].toFixed(1) + '" y2="' + ax[1].toFixed(1) + '" stroke="#cccccc" stroke-width="1"/>');
      var lp = pt(maxR + 22, a), anchor = "middle";
      if (lp[0] > cx + 1) anchor = "start"; else if (lp[0] < cx - 1) anchor = "end";
      var value = byFn[func] || 0;
      p.push('<text x="' + lp[0].toFixed(1) + '" y="' + lp[1].toFixed(1) + '" text-anchor="' + anchor + '" font-size="12" fill="#333333">' + escapeHtml(func) + "</text>");
      p.push('<text x="' + lp[0].toFixed(1) + '" y="' + (lp[1] + 14).toFixed(1) + '" text-anchor="' + anchor + '" font-size="10" fill="#888888">' + fmtG(value) + "/5</text>");
    });
    var dpts = functions.map(function (func, i) {
      var value = Math.max(0, Math.min(MAX, byFn[func] || 0));
      return pt(maxR * value / MAX, angles[i]);
    });
    var ds = dpts.map(function (q) { return q[0].toFixed(1) + "," + q[1].toFixed(1); }).join(" ");
    p.push('<polygon points="' + ds + '" fill="#2b6cb0" fill-opacity="0.30" stroke="#2b6cb0" stroke-width="2"/>');
    dpts.forEach(function (q) { p.push('<circle cx="' + q[0].toFixed(1) + '" cy="' + q[1].toFixed(1) + '" r="3" fill="#2b6cb0"/>'); });
    p.push("</svg>");
    return p.join("");
  }

  function readForm() {
    return {
      name: el("name").value.trim(),
      sector: el("sector").value,
      employees: parseInt(el("employees").value, 10) || 0,
      turnover: parseFloat(el("turnover").value) || 0,
      is_public_body: el("is_public_body").checked,
      is_trust: el("is_trust").checked
    };
  }

  // --- Assessment: replica run_assessment() do motor (assessment.py) ---
  function runAssessment(level, answers) {
    var required = CFG.controls.filter(function (c) { return c.levels[level]; });
    var implemented = 0, maturitySum = 0;
    var fnSum = {}, fnCount = {}, gaps = [];
    required.forEach(function (c) {
      var m = answers[c.id] || 0;
      var isImpl = m >= CFG.maturity_threshold;
      if (isImpl) implemented++;
      maturitySum += m;
      fnSum[c.fn] = (fnSum[c.fn] || 0) + m;
      fnCount[c.fn] = (fnCount[c.fn] || 0) + 1;
      gaps.push({ control: c, implemented: isImpl, priority: CFG.priority_by_function[c.fn] || "media", maturity: m });
    });
    var n = required.length;
    var byFn = {};
    Object.keys(fnSum).forEach(function (f) { byFn[f] = round2(fnSum[f] / fnCount[f]); });
    var prioOrder = { alta: 0, media: 1, baixa: 2 };
    gaps.sort(function (a, b) {
      return (a.implemented - b.implemented) || (prioOrder[a.priority] - prioOrder[b.priority]);
    });
    return {
      required: n,
      score_pct: n ? round1(implemented / n * 100) : 0,
      maturity_score_pct: n ? round1(maturitySum / (n * 5) * 100) : 0,
      maturity_by_function: byFn,
      gaps: gaps
    };
  }

  function renderClassification() {
    var entity = readForm();
    var res = classify(entity);
    var meta = META[res.tipo];
    var nivel = LEVELS[res.tipo];
    el("result").className = "result r-" + meta.cls;
    el("result").innerHTML =
      '<div>Classificação provisória</div><div class="tipo">' + meta.rotulo + '</div>' +
      (nivel ? '<div class="nivel">Nível de conformidade exigido: <strong>' + nivel + '</strong></div>'
             : '<div class="nivel">Sem nível exigido</div>');
    el("motivo").innerHTML = "<strong>Porquê:</strong> " + res.motivo;
    el("sector-hint").textContent = CFG.sectorHints[entity.sector] || "";
    return { entity: entity, res: res, nivel: nivel };
  }

  function renderQuestionnaire(nivel) {
    var box = el("questionnaire");
    if (!nivel) {
      el("assess-intro").textContent = "Entidade fora de âmbito — não há questionário de maturidade a preencher.";
      box.innerHTML = "";
      el("results-card").classList.add("hidden");
      return;
    }
    var required = CFG.controls.filter(function (c) { return c.levels[nivel]; });
    el("assess-intro").textContent =
      "Indica a maturidade (0-5) de cada um dos " + required.length +
      " controlos exigidos para o nível " + nivel + ". 0=Inexistente, 3=Definido (implementado), 5=Otimizado.";
    // Agrupa por função QNRCS, pela ordem em que aparecem.
    var byFn = {};
    var fnOrder = [];
    required.forEach(function (c) {
      if (!byFn[c.fn]) { byFn[c.fn] = []; fnOrder.push(c.fn); }
      byFn[c.fn].push(c);
    });
    var html = "";
    fnOrder.forEach(function (fn) {
      html += '<div class="q-fn">' + escapeHtml(fn) + '</div>';
      byFn[fn].forEach(function (c) {
        var cur = answersState[c.id] || 0;
        var opts = "";
        for (var i = 0; i <= 5; i++) {
          opts += '<option value="' + i + '"' + (i === cur ? " selected" : "") + '>' + i + " · " + escapeHtml(CFG.maturity_labels[String(i)]) + "</option>";
        }
        html += '<div class="q-row"><div class="t"><strong>' + escapeHtml(c.id) + '</strong> ' + escapeHtml(c.title) +
          '</div><select data-cid="' + escapeHtml(c.id) + '">' + opts + "</select></div>";
      });
    });
    box.innerHTML = html;
    box.querySelectorAll("select[data-cid]").forEach(function (sel) {
      sel.addEventListener("change", function () {
        answersState[sel.getAttribute("data-cid")] = parseInt(sel.value, 10) || 0;
        renderResults(nivel);
      });
    });
    renderResults(nivel);
  }

  function renderResults(nivel) {
    var r = runAssessment(nivel, answersState);
    el("results-card").classList.remove("hidden");
    var openGaps = r.gaps.filter(function (g) { return !g.implemented; }).length;
    el("kpis").innerHTML =
      kpi(r.score_pct + "%", "Conformidade") +
      kpi(r.maturity_score_pct + "%", "Maturidade média") +
      kpi(openGaps, "Gaps abertos") +
      kpi(r.required, "Controlos exigidos");

    var fnRows = Object.keys(r.maturity_by_function).sort().map(function (f) {
      return "<tr><td>" + escapeHtml(f) + "</td><td>" + r.maturity_by_function[f] + " / 5</td></tr>";
    }).join("");
    el("by-function").innerHTML = '<table><thead><tr><th>Função</th><th>Maturidade média (0-5)</th></tr></thead><tbody>' + fnRows + "</tbody></table>";

    // Roadmap: gaps abertos agrupados por fase/prioridade (replica build_remediation_roadmap).
    var rm = "";
    CFG.phases.forEach(function (ph) {
      var gs = r.gaps.filter(function (g) { return !g.implemented && g.priority === ph.priority; });
      if (!gs.length) return;
      rm += '<h3>' + escapeHtml(ph.name) + " (" + escapeHtml(ph.timeframe) + ") — prioridade " + ph.priority.toUpperCase() + "</h3>";
      rm += '<table><thead><tr><th>Controlo</th><th>Função</th><th>Maturidade</th></tr></thead><tbody>' +
        gs.map(function (g) {
          return "<tr><td><strong>" + escapeHtml(g.control.id) + "</strong> " + escapeHtml(g.control.title) +
            "</td><td>" + escapeHtml(g.control.fn) + "</td><td>" + g.maturity + "</td></tr>";
        }).join("") + "</tbody></table>";
    });
    el("roadmap").innerHTML = rm || '<p class="vazio">Sem gaps abertos — todos os controlos exigidos estão implementados (maturidade ≥ ' + CFG.maturity_threshold + ").</p>";

    el("radar").innerHTML = radarSvg(r.maturity_by_function);
    return r;
  }

  // Gera um relatório HTML self-contained a partir do assessment do browser,
  // espelhando a estrutura do report.html.j2 do motor (cabeçalho/marca, cards,
  // radar embebido, tabela de gaps e rodapé).
  function buildReportHtml(entity, nivel, classificacao) {
    var r = runAssessment(nivel, answersState);
    var openGaps = r.gaps.filter(function (g) { return !g.implemented; });
    var date = new Date().toISOString().slice(0, 10);
    var prioCls = { alta: "prio-alta", media: "prio-media", baixa: "prio-baixa" };
    var cap = function (s) { return s ? s.charAt(0).toUpperCase() + s.slice(1) : s; };
    var rows = openGaps.length
      ? openGaps.map(function (g) {
          return "<tr><td>" + escapeHtml(g.control.id) + "</td><td>" + escapeHtml(g.control.title) +
            "</td><td>" + escapeHtml(g.control.fn) + '</td><td class="' + prioCls[g.priority] + '">' + cap(g.priority) +
            '</td><td class="gap">Em falta</td></tr>';
        }).join("")
      : '<tr><td colspan="5" class="ok">Sem gaps abertos para o nível-alvo. 🎉</td></tr>';
    return '<!DOCTYPE html>\n<html lang="pt"><head><meta charset="utf-8"/>' +
      "<title>Relatório de Conformidade NIS2 — " + escapeHtml(entity.name) + "</title><style>" +
      "*{box-sizing:border-box;}body{font-family:-apple-system,'Segoe UI',Roboto,sans-serif;color:#1a1a1a;max-width:900px;margin:0 auto;padding:40px 32px;line-height:1.5;}" +
      "header{border-bottom:3px solid #2b6cb0;padding-bottom:16px;margin-bottom:28px;display:flex;justify-content:space-between;align-items:baseline;}" +
      "header .brand{font-size:20px;font-weight:700;color:#2b6cb0;}header .date{color:#666;font-size:13px;}" +
      "h1{font-size:24px;margin:0 0 4px;}h2{font-size:18px;margin-top:32px;border-bottom:1px solid #eee;padding-bottom:4px;}" +
      ".meta{color:#555;font-size:14px;margin-bottom:24px;}.cards{display:flex;gap:16px;margin:24px 0;}" +
      ".card{flex:1;background:#f7fafc;border:1px solid #e2e8f0;border-radius:8px;padding:16px;text-align:center;}" +
      ".card .value{font-size:30px;font-weight:700;color:#2b6cb0;}.card .label{font-size:12px;color:#666;text-transform:uppercase;letter-spacing:.04em;}" +
      ".radar{text-align:center;margin:24px 0;}table{width:100%;border-collapse:collapse;font-size:13px;margin-top:12px;}" +
      "th,td{border:1px solid #e2e8f0;padding:6px 8px;text-align:left;}th{background:#f7fafc;}.ok{color:#2f855a;font-weight:600;}.gap{color:#c53030;font-weight:600;}" +
      ".prio-alta{color:#c53030;font-weight:600;}.prio-media{color:#b7791f;}.prio-baixa{color:#718096;}" +
      "footer{margin-top:40px;padding-top:16px;border-top:1px solid #eee;color:#888;font-size:12px;}@media print{body{padding:0;}}</style></head><body>" +
      '<header><span class="brand">' + escapeHtml(CFG.brand) + '</span><span class="date">' + date + "</span></header>" +
      "<h1>Relatório de Conformidade NIS2</h1>" +
      '<div class="meta"><strong>' + escapeHtml(entity.name) + "</strong> — " + escapeHtml(classificacao) +
      ", nível-alvo <strong>" + cap(nivel) + "</strong><br/>Setor: " + escapeHtml(entity.sector) + " · " + entity.employees +
      " trabalhadores · " + entity.turnover + " € volume de negócios</div>" +
      '<div class="cards"><div class="card"><div class="value">' + r.score_pct + '%</div><div class="label">Conformidade</div></div>' +
      '<div class="card"><div class="value">' + r.maturity_score_pct + '%</div><div class="label">Maturidade média</div></div>' +
      '<div class="card"><div class="value">' + openGaps.length + '</div><div class="label">Gaps abertos</div></div></div>' +
      '<h2>Maturidade por função (QNRCS)</h2><div class="radar">' + radarSvg(r.maturity_by_function) + "</div>" +
      "<h2>Gaps prioritários</h2><table><thead><tr><th>ID</th><th>Controlo</th><th>Função</th><th>Prioridade</th><th>Estado</th></tr></thead><tbody>" +
      rows + "</tbody></table>" +
      "<footer>Relatório gerado no browser pelo formulário de conformidade NIS2 (DL 125/2025 + Regulamento n.º 756/2026). " +
      "Os crosswalks legais devem ser validados artigo-a-artigo contra o texto oficial antes de uso formal.</footer></body></html>";
  }

  function kpi(v, l) { return '<div class="kpi"><div class="v">' + v + '</div><div class="l">' + l + "</div></div>"; }

  // --- Histórico (localStorage) ---
  function loadHistory() { try { return JSON.parse(localStorage.getItem(STORAGE_KEY)) || []; } catch (e) { return []; } }
  function saveHistory(list) { localStorage.setItem(STORAGE_KEY, JSON.stringify(list)); }

  function renderHistory() {
    var list = loadHistory();
    var box = el("history");
    if (!list.length) { box.innerHTML = '<p class="vazio">Sem classificações guardadas.</p>'; return; }
    var rows = list.map(function (h, i) {
      var meta = META[h.tipo];
      return "<tr><td>" + (i + 1) + "</td><td>" + escapeHtml(h.name || "(sem nome)") + "</td><td>" + escapeHtml(h.sector) +
        "</td><td>" + h.employees + "</td><td>" + fmtEur(h.turnover) + '</td><td><span class="badge b-' + meta.cls + '">' + meta.rotulo +
        "</span></td><td>" + (h.nivel || "—") + "</td><td>" + new Date(h.at).toLocaleString("pt-PT") + "</td></tr>";
    }).join("");
    box.innerHTML = "<table><thead><tr><th>#</th><th>Entidade</th><th>Setor</th><th>Trab.</th><th>Volume</th>" +
      "<th>Classificação</th><th>Nível</th><th>Data</th></tr></thead><tbody>" + rows + "</tbody></table>";
  }

  function escapeHtml(s) {
    return String(s).replace(/[&<>"']/g, function (c) {
      return { "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" }[c];
    });
  }

  function download(filename, text, mime) {
    var blob = new Blob([text], { type: mime || "text/plain;charset=utf-8" });
    var a = document.createElement("a");
    a.href = URL.createObjectURL(blob); a.download = filename; a.click();
    URL.revokeObjectURL(a.href);
  }

  function slugify(s) { return (s || "entidade").toLowerCase().replace(/[^a-z0-9]+/g, "_").replace(/^_|_$/g, "") || "entidade"; }

  function render() {
    var c = renderClassification();
    var nivel = renderRiskMatrix(c);  // nível efetivo (matriz agregada com tipo)
    renderQuestionnaire(nivel);
    return c;
  }

  // --- Eventos ---
  ["name", "sector", "employees", "turnover", "is_public_body", "is_trust"].forEach(function (id) {
    el(id).addEventListener("input", render);
    el(id).addEventListener("change", render);
  });

  el("btn-add-scenario").addEventListener("click", function () {
    riskScenarios.push({ name: "Novo cenário", actor: "", prob: 3, impacto: 3 });
    render();
  });

  el("btn-save").addEventListener("click", function () {
    var c = render();
    var list = loadHistory();
    list.push({ name: c.entity.name, sector: c.entity.sector, employees: c.entity.employees,
      turnover: c.entity.turnover, tipo: c.res.tipo, nivel: c.nivel || "", at: Date.now() });
    saveHistory(list); renderHistory();
  });

  el("btn-yaml").addEventListener("click", function () {
    var e = readForm();
    var yaml = "name: " + (e.name || "Entidade sem nome") + "\nsector: " + e.sector +
      "\nemployees: " + e.employees + "\nannual_turnover_eur: " + e.turnover +
      "\nis_public_body: " + (e.is_public_body ? "true" : "false") +
      "\nis_dns_tld_or_trust_service_provider: " + (e.is_trust ? "true" : "false") + "\n";
    download(slugify(e.name) + ".yaml", yaml, "text/yaml;charset=utf-8");
  });

  el("btn-answers").addEventListener("click", function () {
    var c = readForm();
    var nivel = effectiveLevelFor(c);
    var required = CFG.controls.filter(function (cc) { return nivel && cc.levels[nivel]; });
    var lines = ["entity: " + (c.name || "Entidade sem nome"), "target_level: " + nivel, "answers:"];
    required.forEach(function (cc) {
      var m = answersState[cc.id] || 0;
      lines.push("- control_id: " + cc.id);
      lines.push("  title: " + JSON.stringify(cc.title));
      lines.push("  qnrcs_function: " + cc.fn);
      lines.push("  implemented: " + (m >= CFG.maturity_threshold ? "true" : "false"));
      lines.push("  maturity: " + m);
      lines.push("  notes: ''");
    });
    download(slugify(c.name) + "_answers.yaml", lines.join("\n") + "\n", "text/yaml;charset=utf-8");
  });

  el("btn-report").addEventListener("click", function () {
    var c = readForm();
    var cl = classify(c);
    var nivel = effectiveLevelFor(c);
    if (!nivel) { alert("Entidade fora de âmbito — não há relatório de conformidade a gerar."); return; }
    var html = buildReportHtml(c, nivel, META[cl.tipo].rotulo);
    download(slugify(c.name) + "_relatorio.html", html, "text/html;charset=utf-8");
  });

  el("btn-export").addEventListener("click", function () {
    var list = loadHistory();
    var head = "nome,setor,trabalhadores,volume_negocios_eur,classificacao,nivel_exigido,data\n";
    var body = list.map(function (h) {
      return ['"' + (h.name || "").replace(/"/g, '""') + '"', h.sector, h.employees, h.turnover, h.tipo, h.nivel || "", new Date(h.at).toISOString()].join(",");
    }).join("\n");
    download("historico_classificacoes.csv", head + body + "\n", "text/csv;charset=utf-8");
  });

  el("btn-clear").addEventListener("click", function () {
    if (confirm("Limpar todo o histórico guardado neste browser?")) { localStorage.removeItem(STORAGE_KEY); renderHistory(); }
  });

  render();
  renderHistory();
})();
</script>
</body>
</html>
